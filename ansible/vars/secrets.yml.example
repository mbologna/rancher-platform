---
# ── Secrets template ─────────────────────────────────────────────────────────
# Copy this file to secrets.yml and fill in your values.
# secrets.yml is gitignored — never commit real credentials.
#
#   cp ansible/vars/secrets.yml.example ansible/vars/secrets.yml
#   vi ansible/vars/secrets.yml

# Default password for the Rancher admin user.
rancher_bootstrap_password: "CHANGE_ME"

# AWS and Metal3 credentials for CAPI provisioning are NOT configured here.
# They live as Kubernetes Secrets on the management cluster and are set up
# as part of the rancher-fleet-clusters workflow:
# https://github.com/mbologna/rancher-fleet-clusters#step-1--aws-credentials-skip-if-not-using-aws-examples
