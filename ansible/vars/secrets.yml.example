---
# ── Secrets template ─────────────────────────────────────────────────────────
# Copy this file to secrets.yml and fill in your values.
# secrets.yml is gitignored — never commit real credentials.
#
#   cp ansible/vars/secrets.yml.example ansible/vars/secrets.yml
#   vi ansible/vars/secrets.yml

# CAPA (AWS) credentials — applied directly to the cluster by Ansible (not via Fleet)
# These become a Secret named "cluster-identity" in namespace "default",
# referenced by the AWSClusterStaticIdentity in the cluster manifest.
capa_credentials:
  aws_access_key_id: "CHANGE_ME"
  aws_secret_access_key: "CHANGE_ME"
  aws_region: "eu-west-1"

# CAPM3 (Metal3 / Ironic) credentials — applied directly by Ansible.
# Leave CHANGE_ME if you are not using Metal3.
capm3_credentials:
  ironic_url: "http://CHANGE_ME:6385/v1/"
  ironic_inspector_url: "http://CHANGE_ME:5050/v1/"
  ironic_username: "CHANGE_ME"
  ironic_password: "CHANGE_ME"

# Default password for the Rancher admin user
rancher_bootstrap_password: "CHANGE_ME"
