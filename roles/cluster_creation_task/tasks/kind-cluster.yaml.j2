kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: {{ cluster.name }}
networking:
  disableDefaultCNI: false
nodes:
{% if cluster.name == management_cluster %}
- role: control-plane
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: control-plane
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: control-plane
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
  kubeadmConfigPatches:
  - |
    kind: InitConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "ingress-ready=true,node-type=management"
  - |
    kind: ClusterConfiguration
    apiServer:
      extraArgs:
        "service-node-port-range": "30000-32767"
  extraPortMappings:
  - containerPort: 80
    hostPort: 80
    protocol: TCP
  - containerPort: {{ rancher_ports.https }}
    hostPort: 443
    protocol: TCP
  - containerPort: 30000
    hostPort: 8080
    protocol: TCP
  - containerPort: 30001
    hostPort: 9090
    protocol: TCP
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
{% else %}
- role: control-plane
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
  kubeadmConfigPatches:
  - |
    kind: InitConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "node-type=workload-cp,cluster={{ cluster.name }}"
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
- role: worker
  image: kindest/node:{{ management_cluster_versions.kubernetes }}
  kubeadmConfigPatches:
  - |
    kind: JoinConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "node-type=workload-worker,cluster={{ cluster.name }}"
{% endif %}
